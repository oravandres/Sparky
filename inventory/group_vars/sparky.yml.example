---
# Example for inventory/group_vars/sparky.yml — see PLAN.md §10.
#
# The real file MUST be encrypted with `ansible-vault` and is gitignored.
# Vault password file lives in ~/.ansible-vault-pass on the operator workstation,
# never in this repo.
#
# Encrypt with:
#   ansible-vault encrypt inventory/group_vars/sparky.yml
# Edit with:
#   ansible-vault edit inventory/group_vars/sparky.yml

# --- Sparky host identity ---
sparky_hostname: sparky.mimi.local
sparky_lan_ip: 10.0.0.50              # change to actual LAN IP
sparky_admin_user: andres

# --- Storage mount discovered in preflight (PLAN.md §8) ---
sparky_data_mount: /data
# Single-NVMe DGX Spark setup — when the entire NVMe is mounted at `/`
# and there is no separate /data partition, opt into the bind-mount
# path so roles/storage can record a bind mount in /etc/fstab.
# sparky_data_use_bind_mount: true
# sparky_data_bind_source: /var/sparky-data

# --- Phase 2 container runtime + NVIDIA validation (PLAN.md §11) ---
# DGX Spark ships preconfigured. The role only validates and refuses
# to (re)install the vendor stack. Override the CUDA image when DGX
# Spark requires NVIDIA's vendor tag for the in-container probe.
# sparky_containers_install_packages: false
# sparky_nvidia_cuda_image: "nvidia/cuda:12.6.3-runtime-ubuntu22.04"
# sparky_nvidia_validate_container: true
# sparky_nvidia_container_failure_is_fatal: true

# --- Phase 1 base OS / firewall (playbooks/10-base-os.yml) ---
# Firewall defaults are OFF — enable only after setting real CIDRs below.
# sparky_configure_firewall: false
# sparky_firewall_cidr_confirmed: false   # must become true once admin/internal/monitoring CIDRs match your LAN/VPN
# sparky_admin_cidr: 10.0.0.0/8           # SSH sources — replace placeholder
# sparky_internal_cidr: 10.0.0.0/8       # gateway 8080 — MiMi / DarkBase
# sparky_monitoring_cidr: 10.0.0.0/8      # Prometheus scrapers
# sparky_ssh_harden: false               # true only after SSH keys verified
# sparky_ssh_password_authentication: true
# sparky_apt_upgrade: false               # true runs apt full upgrade (disruptive)

# --- Secrets (placeholders only; real values via ansible-vault) ---
hf_token: ""                          # Hugging Face token for gated weights
ngc_api_key: ""                       # NVIDIA NGC API key

# SPARKY_API_KEY is NOT defined here. It is generated once with
# `openssl rand -hex 32`, registered as the sealed secret `sparky-api-key`
# in MiMi-Secrets, and mirrored to /etc/sparky/sparky.env on the host
# (mode 0640, root:sparky). See PLAN.md §10.

# --- Optional K3s join controls (PLAN.md §2.1) ---
sparky_join_k3s: false
sparky_node_labels:
  - "node-role.mimi.local/sparky=true"
  - "hardware.nvidia.com/dgx-spark=true"
  - "workload.mimi.local/premium-ai=true"
sparky_node_taints:
  - "workload.mimi.local/premium-ai=true:NoSchedule"
