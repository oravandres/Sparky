# Top-level workstation/agent helpers.
# Real env files for runtime services live at /etc/sparky/sparky.env on the host
# (sourced from MiMi-Secrets per PLAN.md §10). See config/sparky.env.example.

# Used only by ansible runs from this checkout. Never commit real values.
ANSIBLE_VAULT_PASSWORD_FILE=~/.ansible-vault-pass

# Optional: override default inventory.
# ANSIBLE_INVENTORY=inventory/hosts.yml
