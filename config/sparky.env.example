# Sparky runtime environment — see PLAN.md §7.4 / §10.
#
# The real file MUST live at /etc/sparky/sparky.env (mode 0640, root:sparky)
# and is mirrored from MiMi-Secrets ("sparky-api-key" sealed secret).
# Compose resolves `env_file: ${SPARKY_ENV_FILE:-/etc/sparky/sparky.env}` — scripts/start-gateway.sh
# exports SPARKY_ENV_FILE when you override the path (defaults to /etc/sparky/sparky.env).
# Never commit a real version of this file.

# --- gateway ---
SPARKY_API_KEY=                          # required, generated with: openssl rand -hex 32
SPARKY_GATEWAY_BIND=0.0.0.0:8080
SPARKY_LOG_LEVEL=info
SPARKY_REQUEST_TIMEOUT_SECONDS=120
# SPARKY_CHAT_MAX_MESSAGES=64
# SPARKY_CHAT_MAX_CONTENT_CHARS=120000
# SPARKY_NEMOTRON_MAX_INFLIGHT=2
# SPARKY_MAX_REQUEST_BODY_BYTES=2097152
# SPARKY_ENABLE_OPENAPI_DOCS=false    # dev-only; never enable on LAN-facing installs without auth

# --- runtimes (kept on loopback per §4.1; gateway proxies them) ---
NEMOTRON_VLLM_URL=http://127.0.0.1:8000
NEMOTRON_TRTLLM_URL=http://127.0.0.1:8001
COMFYUI_URL=http://127.0.0.1:8188
AUDIO_SERVICE_URL=http://127.0.0.1:9001

# --- paths (see §8 — discovered in preflight, may be overridden) ---
MODELS_DIR=/data/models
CACHE_DIR=/data/cache
OUTPUTS_DIR=/data/outputs
JOBS_DIR=/var/lib/sparky/jobs
LOGS_DIR=/var/log/sparky

# --- model downloads ---
HF_TOKEN=                                # required for some weights
NGC_API_KEY=                             # required for NVIDIA NGC pulls

# --- monitoring ---
ENABLE_GPU_EXPORTER=true
