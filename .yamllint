---
# yamllint config — see PLAN.md §22
extends: default

rules:
  line-length:
    max: 160
    level: warning
  truthy:
    allowed-values: ["true", "false"]
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  braces:
    max-spaces-inside: 1
  brackets:
    max-spaces-inside: 1
  indentation:
    spaces: 2
    indent-sequences: consistent
  document-start: disable
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: false

ignore: |
  .ansible_cache/
  .venv/
  node_modules/
  config/api-contract.yaml
